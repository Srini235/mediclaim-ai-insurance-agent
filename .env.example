# Copy to .env and fill in your key. The .env file is gitignored — never commit real keys.
#
# OpenRouter (https://openrouter.ai) powers the RAG advisor's optional LLM generation.
# Without a key the system falls back to the offline TF-IDF retriever, so it still runs.
OPENROUTER_API_KEY=OPENROUTER_API_KEY
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
